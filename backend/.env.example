# --- Supabase project (the one you created in supabase-export/README.md) ---
SUPABASE_SERVICE_ROLE_KEY=Your Supabase service role key (found in supabase dashboard > settings > api)
SUPABASE_ANON_KEY=Your Supabase anon key (found in supabase dashboard > settings > api)
SUPABASE_URL=Your Supabase URL (found in supabase dashboard > settings > api)
# --- Lovable AI Gateway (works from any Node host) ---
LOVABLE_API_KEY=lk_live_...

# --- Server config ---
PORT=8787

# Comma-separated list of origins allowed to call this API.
# Include localhost for dev and your deployed Vercel domain for prod.
ALLOWED_ORIGINS=http://localhost:8080,https://your-app.vercel.app
